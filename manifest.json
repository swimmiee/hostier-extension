{
  "manifest_version": 3,
  "name": "Hostroom",
  "version": "1.0.0",
  "default_locale": "ko",
  "description": "__MSG_extDescription__",
  "permissions": ["cookies", "storage", "alarms", "notifications", "scripting"],
  "externally_connectable": {
    "matches": ["https://hostroom.vercel.app/*", "http://localhost:3000/*"]
  },
  "host_permissions": [
    "https://web.33m2.co.kr/*",
    "https://host.enko.kr/*",
    "https://*.liveanywhere.me/*",
    "https://hostroom.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
