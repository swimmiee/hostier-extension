{
  "manifest_version": 3,
  "name": "Hostroom",
  "version": "1.0.0",
  "description": "숙소 플랫폼 예약 동기화",
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "https://web.33m2.co.kr/*",
    "https://host.enko.kr/*",
    "https://*.liveanywhere.me/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
