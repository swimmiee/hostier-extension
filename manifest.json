{
  "manifest_version": 3,
  "name": "Hostier",
  "version": "2.0.0",
  "default_locale": "ko",
  "description": "__MSG_extDescription__",
  "permissions": [
    "cookies",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://hostier.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "optional_host_permissions": [
    "https://web.33m2.co.kr/*",
    "https://host.enko.kr/*",
    "https://*.liveanywhere.me/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
