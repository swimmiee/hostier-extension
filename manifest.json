{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.1.6",
  "default_locale": "ko",
  "description": "__MSG_extDescription__",
  "permissions": [
    "cookies",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:5173/*"
  ],
  "optional_host_permissions": [
    "https://web.33m2.co.kr/*",
    "https://host.enko.kr/*",
    "https://*.liveanywhere.me/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*"
      ],
      "js": [
        "install-detector.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
